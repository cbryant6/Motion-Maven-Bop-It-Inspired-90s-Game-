"""
====================================================================
 MOTION MAVEN — Main Game Loop & State Machine
====================================================================

 Hardware:   XIAO ESP32-C3
             128×64 OLED (SSD1306 over I2C)
             ADXL345 3-axis accelerometer (I2C)
             Rotary encoder with push button
             Arcade button (power toggle)
             WS2812B NeoPixel RGB LED
             Piezo buzzer

 Language:   CircuitPython

 Overview:   Motion Maven is a handheld motion-controlled game
             inspired by Bop It. The player performs physical
             gestures — tilts, spins, and shakes — within
             shrinking time limits as difficulty increases. This
             file contains the main game loop, state machine,
             input handling, and UI rendering. Hardware-specific
             logic (motion processing, audio, score persistence)
             is separated into dedicated modules.

 Architecture:
   code.py         ← this file: state machine, game loop, UI
   motion.py       ← calibration, IIR smoothing, tilt/shake detection
   audio.py        ← piezo melodies and sound effects
   highscores.py   ← persistent score storage on flash

 Design decisions:
   - STATE MACHINE PATTERN: The game uses an explicit state
     machine (MENU → PLAY → RESULT → HS_ENTRY → HS_SHOW)
     rather than nested function calls. This keeps the main
     loop flat and makes it easy to add new states (e.g. a
     tutorial or settings screen) without refactoring control
     flow. Each state owns its own rendering and input logic.

   - POWER TOGGLE VIA ARCADE BUTTON: Rather than a physical
     power switch, the arcade button toggles a software power
     state. This avoids needing a latching switch and lets us
     run a splash animation on every "power on" — a small UX
     detail that makes the device feel more polished.

   - MODULAR CODEBASE: Motion processing, audio, and score
     persistence are separated into their own files. This was
     a deliberate choice to keep the main game logic readable
     and to allow each module to be tested and tuned
     independently. For a PM audience: this mirrors how you'd
     scope work across team members on a real product.

   - ENCODER FOR MENU + SPIN MOVES: The rotary encoder serves
     double duty — menu navigation and in-game spin detection.
     This reduces part count and BOM cost while creating a
     natural mapping (twist to navigate, twist to play).

   - PROGRESSIVE DIFFICULTY: Time limits shrink by 0.1s per
     round (not per difficulty level). This creates a smooth
     difficulty curve within a single game session, so even
     Easy mode gets challenging by round 11. The floor is
     capped at 0.5s to prevent impossible rounds.

   - SPEED-BASED SCORING: 100 base points + up to 200 bonus
     based on remaining time. This rewards fast reactions
     without punishing slower players — you still get points
     for completing the move, you just get more for being quick.

 Author:     Coleman Bryant
 Course:     TECHIN 512 — Hardware/Software Lab (Sensors & Circuits)
 Program:    MSTI, University of Washington
====================================================================
"""

import time
import random
import board
import digitalio
import displayio
import terminalio
import neopixel

from adafruit_display_text import label
import i2cdisplaybus
import adafruit_displayio_ssd1306
import adafruit_adxl34x

import highscores as hs       # persistent score storage on flash
import audio as snd            # piezo melodies and sound effects
import motion as mv            # calibration, smoothing, tilt/shake


# =====================================================================
#  SOFTWARE ROTARY ENCODER
# =====================================================================
# The XIAO ESP32-C3 running CircuitPython doesn't have hardware
# encoder support, so we implement a simple software decoder using
# falling-edge detection on both channels. This is sufficient at
# human interaction speeds (~1-3 Hz rotation) and avoids needing
# an interrupt-driven approach.

class SoftEncoder:
    """
    Software quadrature decoder for a rotary encoder.
    Tracks net position by detecting falling edges on A and B
    channels and using the opposite channel's state to determine
    direction. Pull-ups are enabled since the encoder switches
    are open-drain.
    """

    def __init__(self, pinA, pinB):
        self.pinA = digitalio.DigitalInOut(pinA)
        self.pinB = digitalio.DigitalInOut(pinB)

        self.pinA.direction = digitalio.Direction.INPUT
        self.pinB.direction = digitalio.Direction.INPUT
        self.pinA.pull = digitalio.Pull.UP
        self.pinB.pull = digitalio.Pull.UP

        self.last_state = (self.pinA.value, self.pinB.value)
        self.position = 0

    def update(self):
        a, b = self.pinA.value, self.pinB.value
        last_a, last_b = self.last_state

        if (a, b) != self.last_state:
            # Falling edge on A → check B to determine direction
            if last_a == 1 and a == 0:
                if b == 1:
                    self.position += 1
                else:
                    self.position -= 1

            # Falling edge on B → check A to determine direction
            elif last_b == 1 and b == 0:
                if a == 0:
                    self.position += 1
                else:
                    self.position -= 1

        self.last_state = (a, b)


# =====================================================================
#  PIN DEFINITIONS
# =====================================================================
# All pin assignments are centralized here for easy hardware revisions.
# The buzzer pin (D7) is defined inside audio.py to keep sound logic
# self-contained.

PIXEL_PIN   = board.D6     # NeoPixel data line
BUTTON_PIN  = board.D10    # Arcade button (power toggle)
ENC_A_PIN   = board.D2     # Rotary encoder channel A (CLK)
ENC_B_PIN   = board.D3     # Rotary encoder channel B (DT)
ENC_BTN_PIN = board.D9     # Encoder push button (menu select / game ack)


# =====================================================================
#  GAME STATE CONSTANTS & GLOBALS
# =====================================================================
# The game uses a flat state machine with five states. Transitions
# are handled explicitly in the main loop, making the control flow
# easy to follow and extend.
#
#   MENU ──→ PLAY ──→ RESULT ──→ HS_ENTRY ──→ HS_SHOW ──→ MENU
#                        │                        ↑
#                        └── (no high score) ─────┘

STATE_MENU     = "MENU"
STATE_PLAY     = "PLAY"
STATE_RESULT   = "RESULT"
STATE_HS_ENTRY = "HS_ENTRY"
STATE_HS_SHOW  = "HS_SHOW"

# ── Power Management ────────────────────────────────────────
# Software power state — device starts "off" until the arcade
# button is pressed. This avoids accidental game starts when
# the battery is connected.
is_powered_on = False
game_state    = STATE_MENU
splash_shown  = False

# ── Difficulty Configuration ────────────────────────────────
# Three difficulty tiers control the base time per move and
# which moves are available. Easy mode restricts to spins and
# shakes only (no tilts), lowering the motor skill barrier
# for new players.
DIFFICULTIES   = ["EASY", "MEDIUM", "HARD"]
DIFFICULTY_TIMES = {
    "EASY":   7.0,
    "MEDIUM": 5.0,
    "HARD":   3.0
}
current_difficulty_index = 0
current_difficulty       = DIFFICULTIES[current_difficulty_index]
base_time_limit          = DIFFICULTY_TIMES[current_difficulty]

# ── Round & Score Tracking ──────────────────────────────────
MAX_ROUNDS    = 11
menu_index    = 0
MENU_MAX_INDEX = 2
last_enc_pos  = 0

play_start    = None
play_move     = None       # dict describing the current challenge
play_result   = ""
score         = 0
round_num     = 1
pending_score = 0          # score snapshot for highscore evaluation

# ── Button Edge Detection ───────────────────────────────────
# Both buttons use pull-up resistors and are active-low.
# We track previous values to detect falling edges (presses)
# rather than held states, preventing repeated triggers.
prev_button_value  = True   # arcade button
prev_enc_btn_value = True   # encoder button

# ── Spin Move Configuration ─────────────────────────────────
# Only 1 detent of rotation is required to register a spin.
# This was tuned through playtesting — higher thresholds felt
# unresponsive, while 1 detent gives immediate feedback.
SPIN_REQUIRED_STEPS = 1
move_start_enc_pos  = 0

# ── Move Pools ──────────────────────────────────────────────
# The full move set includes 4 tilts, 2 spins, and 1 shake.
# Easy mode uses a reduced pool (spins + shake only) so new
# players can learn the controls without needing to master
# accelerometer-based tilt detection.

MOVES_ALL = [
    {"type": "TILT",  "direction": "LEFT",    "label": "Tilt LEFT"},
    {"type": "TILT",  "direction": "RIGHT",   "label": "Tilt RIGHT"},
    {"type": "TILT",  "direction": "FORWARD", "label": "Tilt FORWARD"},
    {"type": "TILT",  "direction": "BACK",    "label": "Tilt BACK"},
    {"type": "SPIN",  "direction": "CW",      "label": "Spin CW"},
    {"type": "SPIN",  "direction": "CCW",     "label": "Spin CCW"},
    {"type": "SHAKE", "direction": None,      "label": "Shake!"}
]

MOVES_EASY = [
    {"type": "SPIN",  "direction": "CW",  "label": "Spin CW"},
    {"type": "SPIN",  "direction": "CCW", "label": "Spin CCW"},
    {"type": "SHAKE", "direction": None,  "label": "Shake!"}
]

# ── High Score Entry UI State ───────────────────────────────
hs_initials    = ["A", "A", "A"]
hs_pos         = 0
hs_last_enc_pos = 0
highscores     = []


# =====================================================================
#  OLED TEXT RENDERING
# =====================================================================
# Simple text-based UI. Each screen is rendered as a list of strings
# positioned vertically. This approach was chosen over a pixel-based
# graphics library to keep the codebase accessible and the rendering
# fast on the SSD1306's limited I2C bandwidth.

def show_text(lines):
    """Render a list of strings to the OLED, one per line."""
    group = displayio.Group()
    y = 8
    for text in lines:
        lbl = label.Label(
            terminalio.FONT,
            text=text,
            color=0xFFFFFF,
            x=0,
            y=y
        )
        group.append(lbl)
        y += 12
    display.root_group = group


def clear_display():
    """Blank the OLED when powered off."""
    display.root_group = displayio.Group()


# =====================================================================
#  SPLASH SCREEN ANIMATION
# =====================================================================
# A typewriter-style title animation plays every time the device is
# powered on. This is a small UX polish that makes the device feel
# like a finished product rather than a prototype. The text is
# dynamically centered as characters appear.

def play_splash():
    """Animated 'MOTION MAVEN' title with typewriter effect."""
    global splash_shown

    group = displayio.Group()
    display.root_group = group

    title = "MOTION MAVEN"

    text_area = label.Label(
        terminalio.FONT,
        text="",
        color=0xFFFFFF,
        x=0,
        y=32,       # vertical center on 64px screen
        scale=2     # 2× scale for arcade feel
    )
    group.append(text_area)

    # Typewriter reveal with dynamic centering
    for i in range(len(title) + 1):
        partial = title[:i]
        text_area.text = partial

        # Approximate width: ~6px per character × scale factor
        text_width = len(partial) * 6 * text_area.scale
        text_area.x = (128 - text_width) // 2

        time.sleep(0.08)

    splash_shown = True


# =====================================================================
#  MOVE PICKER
# =====================================================================
# Selects a random move from the pool, avoiding back-to-back repeats.
# Repeats feel unfair in playtesting — the player assumes they did
# something wrong when the same prompt appears twice.

def pick_new_move(previous_move, moves_pool):
    """Pick a random move, avoiding consecutive repeats."""
    if previous_move is None:
        return random.choice(moves_pool)

    candidates = [m for m in moves_pool if m["label"] != previous_move["label"]]
    if not candidates:
        return previous_move
    return random.choice(candidates)


# =====================================================================
#  RECALIBRATION MODE
# =====================================================================
# Lets the player re-zero the accelerometer while seeing live tilt
# feedback. This is important because the ADXL345's "neutral" reading
# depends on how the device is held, and the perfboard mounting angle
# varies between builds. Without recalibration, tilt detection would
# drift and produce false triggers.

def do_recalibration():
    """
    Interactive recalibration screen:
      - Shows live tilt direction for visual confirmation
      - Shows raw X/Y/Z accelerometer values
      - Encoder button press triggers calibration snapshot
    """
    global prev_enc_btn_value

    pixels[0] = (0, 0, 50)  # blue — calibration mode indicator
    local_prev = enc_button.value

    while True:
        x, y, z = accel.acceleration
        tilt_label, raw_label = mv.get_stable_tilt_label(x, y, z)

        show_text([
            "Recalibration Mode",
            f"Tilt: {tilt_label}",
            f"X:{x:5.1f}  Y:{y:5.1f}",
            f"Z:{z:5.1f}",
            "",
            "Enc: Calibrate"
        ])

        current = enc_button.value
        pressed = (local_prev and not current)
        local_prev = current

        if pressed:
            break

        time.sleep(0.1)

    # Snapshot the current orientation as "neutral"
    show_text(["Hold neutral...", "Calibrating..."])
    time.sleep(0.5)

    mv.calibrate(accel)
    mv.reset_smoothing()

    show_text(["Calibration OK", "", "Returning to menu..."])
    time.sleep(0.8)

    # Resync edge detection so the main loop doesn't
    # misread a stale button state
    prev_enc_btn_value = enc_button.value
    pixels[0] = (0, 0, 50)


# =====================================================================
#  HARDWARE INITIALIZATION
# =====================================================================
# All peripherals are initialized at module load. The I2C bus is
# shared between the OLED (0x3C) and accelerometer (0x53) — both
# are standard addresses with no conflicts.

i2c = board.I2C()

displayio.release_displays()
display_bus = i2cdisplaybus.I2CDisplayBus(i2c, device_address=0x3C)

display = adafruit_displayio_ssd1306.SSD1306(
    display_bus,
    width=128,
    height=64
)

accel = adafruit_adxl34x.ADXL345(i2c)

# ── NeoPixel ────────────────────────────────────────────────
# Single WS2812B LED provides at-a-glance state feedback:
#   Blue   → Menu / Idle
#   Yellow → Active gameplay
#   Green  → Successful move
#   Red    → Failed move / Game over
pixels = neopixel.NeoPixel(PIXEL_PIN, 1, brightness=0.35, auto_write=True)
pixels[0] = (0, 0, 0)

# ── Buttons ─────────────────────────────────────────────────
# Both use internal pull-ups and active-low signaling
button = digitalio.DigitalInOut(BUTTON_PIN)
button.direction = digitalio.Direction.INPUT
button.pull = digitalio.Pull.UP

enc_button = digitalio.DigitalInOut(ENC_BTN_PIN)
enc_button.direction = digitalio.Direction.INPUT
enc_button.pull = digitalio.Pull.UP

# ── Encoder ─────────────────────────────────────────────────
encoder = SoftEncoder(ENC_A_PIN, ENC_B_PIN)

# ── Load Saved High Scores ──────────────────────────────────
highscores = hs.load_highscores()


# =====================================================================
#  MAIN LOOP
# =====================================================================
# The main loop runs at ~100 Hz (10 ms sleep) to keep encoder
# and accelerometer input responsive. Each iteration:
#   1. Reads the power button (always, even when "off")
#   2. If powered off, sleeps and skips all game logic
#   3. If powered on, reads all inputs and runs the active state
#
# The loop is intentionally kept flat — no nested function calls
# or callbacks. Every state's logic is inline and self-contained,
# making it easy to trace execution for debugging on a device
# with no debugger (just Serial + OLED).

while True:
    now = time.monotonic()

    # ── 1. POWER BUTTON (always active) ─────────────────────
    # Detect falling edge on the arcade button to toggle power.
    # This runs even when "off" so we can wake up.
    current_button_value = button.value
    if prev_button_value and not current_button_value:
        is_powered_on = not is_powered_on

        if is_powered_on:
            pixels[0] = (0, 0, 50)  # blue — booting

            # Splash animation + startup jingle
            play_splash()
            snd.play_startup()

            # Auto-calibrate on first boot (subsequent boots
            # retain calibration unless user triggers recal)
            if not mv.is_calibrated():
                show_text([
                    "Motion Maven",
                    "Hold neutral...",
                    "Calibrating..."
                ])
                time.sleep(0.5)

                mv.calibrate(accel)
                mv.reset_smoothing()

                show_text([
                    "Motion Maven",
                    "Calibration OK",
                    "",
                    "Rotate to Start"
                ])
                time.sleep(0.8)

            game_state = STATE_MENU
            menu_index = 0
            last_enc_pos = encoder.position

        else:
            # Power off — blank display and LED
            pixels[0] = (0, 0, 0)
            clear_display()

    prev_button_value = current_button_value

    # ── 2. SLEEP WHEN OFF ───────────────────────────────────
    if not is_powered_on:
        time.sleep(0.1)
        continue

    # ── 3. READ ALL INPUTS ──────────────────────────────────
    x, y, z = accel.acceleration
    encoder.update()
    enc_pos = encoder.position

    # Encoder delta since move started (used for spin detection)
    delta = enc_pos - move_start_enc_pos if play_start is not None else 0

    # Smoothed tilt direction from motion module
    tilt_label, raw_tilt = mv.get_stable_tilt_label(x, y, z)

    # Shake detection (acceleration magnitude spike)
    shaking = mv.detect_shake(x, y, z)

    # Encoder button edge detection
    current_enc_btn_value = enc_button.value
    enc_button_pressed = (prev_enc_btn_value and not current_enc_btn_value)
    prev_enc_btn_value = current_enc_btn_value

    # ═════════════════════════════════════════════════════════
    #  STATE MACHINE
    # ═════════════════════════════════════════════════════════

    # ── MENU STATE ──────────────────────────────────────────
    # Three options: Start Game, Difficulty toggle, Recalibrate.
    # Encoder rotates selection, encoder button confirms.
    if game_state == STATE_MENU:
        if enc_pos > last_enc_pos:
            menu_index = min(menu_index + 1, MENU_MAX_INDEX)
        elif enc_pos < last_enc_pos:
            menu_index = max(menu_index - 1, 0)
        last_enc_pos = enc_pos

        arrow0 = ">" if menu_index == 0 else " "
        arrow1 = ">" if menu_index == 1 else " "
        arrow2 = ">" if menu_index == 2 else " "

        show_text([
            "Motion Maven",
            f"{arrow0} Start Game",
            f"{arrow1} Difficulty: {current_difficulty}",
            f"{arrow2} Recalibrate",
            "",
            "Enc btn = select"
        ])

        if enc_button_pressed:
            if menu_index == 0:
                # ── Start Game ──────────────────────────────
                base_time_limit = DIFFICULTY_TIMES[current_difficulty]

                # Easy mode uses reduced move pool (no tilts)
                if current_difficulty == "EASY":
                    move_pool = MOVES_EASY
                else:
                    move_pool = MOVES_ALL

                game_state = STATE_PLAY
                score = 0
                round_num = 1
                play_start = None
                play_result = ""
                pending_score = 0
                play_move = pick_new_move(None, move_pool)
                move_start_enc_pos = encoder.position
                pixels[0] = (50, 50, 0)  # yellow — gameplay active

            elif menu_index == 1:
                # ── Cycle Difficulty ────────────────────────
                current_difficulty_index = (current_difficulty_index + 1) % len(DIFFICULTIES)
                current_difficulty = DIFFICULTIES[current_difficulty_index]

                show_text([
                    "Difficulty set to:",
                    f"   {current_difficulty}",
                    "",
                    "Enc btn: start",
                    "or rotate for menu"
                ])
                time.sleep(0.7)

                # Bounce cursor to Start Game for quick launch
                menu_index = 0
                last_enc_pos = enc_pos

            elif menu_index == 2:
                # ── Recalibrate ─────────────────────────────
                do_recalibration()
                game_state = STATE_MENU
                pixels[0] = (0, 0, 50)

    # ── PLAY STATE ──────────────────────────────────────────
    # Core gameplay loop. Each round:
    #   1. Display the target move
    #   2. Monitor inputs for correct/incorrect/timeout
    #   3. Award points on success, end game on failure
    #
    # Move validation logic is deliberately strict: performing
    # any wrong input type (e.g. shaking when told to tilt)
    # counts as a fail. This forces the player to be deliberate
    # and prevents "mashing" through rounds.
    elif game_state == STATE_PLAY:
        if play_start is None:
            play_start = now
            move_start_enc_pos = encoder.position
            delta = 0

        elapsed = now - play_start

        # Dynamic time limit: shrinks 0.1s per round
        # Round 1 → full base time, Round 11 → base - 1.0s
        time_limit = base_time_limit - 0.1 * (round_num - 1)
        if time_limit < 0.5:
            time_limit = 0.5  # hard floor prevents impossible rounds

        show_text([
            f"Round {round_num}/{MAX_ROUNDS}",
            f"Diff: {current_difficulty}",
            f"Target: {play_move['label']}",
            f"Time:  {elapsed:4.1f}s",
            f"Score: {score}"
        ])

        move_type = play_move["type"]
        success = False
        fail = False

        # ── TILT MOVE VALIDATION ────────────────────────────
        # Uses the smoothed tilt label from motion.py. Only
        # a stable, confirmed tilt in the correct direction
        # counts as success. Any other confirmed direction,
        # spin, or shake is an immediate fail.
        if move_type == "TILT":
            target_dir = play_move["direction"]

            if tilt_label == target_dir:
                success = True
            else:
                if tilt_label in ("LEFT", "RIGHT", "FORWARD", "BACK") and tilt_label != target_dir:
                    fail = True
                elif abs(delta) >= SPIN_REQUIRED_STEPS:
                    fail = True
                elif shaking:
                    fail = True

        # ── SPIN MOVE VALIDATION ────────────────────────────
        # Tracks encoder delta from move start. Spinning the
        # wrong direction is an immediate fail (not just "no
        # progress"). Tilting or shaking during a spin move
        # also fails — this prevents accidental triggers.
        elif move_type == "SPIN":
            if play_move["direction"] == "CW":
                if delta >= SPIN_REQUIRED_STEPS:
                    success = True
                elif delta <= -SPIN_REQUIRED_STEPS:
                    fail = True
            else:  # CCW
                if delta <= -SPIN_REQUIRED_STEPS:
                    success = True
                elif delta >= SPIN_REQUIRED_STEPS:
                    fail = True

            if not success and not fail:
                if tilt_label in ("LEFT", "RIGHT", "FORWARD", "BACK") or shaking:
                    fail = True

        # ── SHAKE MOVE VALIDATION ───────────────────────────
        # Detected via acceleration magnitude spike in
        # motion.py. Spinning during a shake prompt fails.
        elif move_type == "SHAKE":
            if shaking:
                success = True
            elif abs(delta) >= SPIN_REQUIRED_STEPS:
                fail = True

        # ── SUCCESS HANDLING ────────────────────────────────
        # Speed-based scoring: 100 base + up to 200 bonus
        # proportional to remaining time. Fast reactions are
        # rewarded but slow completions still earn points.
        if success:
            remaining = max(0.0, time_limit - elapsed)
            ratio = remaining / time_limit if time_limit > 0 else 0.0
            bonus = int(200 * ratio)
            score += 100 + bonus

            pixels[0] = (0, 120, 0)  # green — success flash
            snd.play_success()
            show_text([
                f"Round {round_num}/{MAX_ROUNDS}",
                "SUCCESS!",
                "",
                f"Score: {score}",
                "Next..."
            ])
            time.sleep(0.5)

            if round_num >= MAX_ROUNDS:
                # All rounds cleared — victory
                play_result = "ALL ROUNDS CLEARED!"
                pending_score = score
                game_state = STATE_RESULT
                pixels[0] = (0, 120, 0)
                snd.play_victory()
            else:
                # Advance to next round
                round_num += 1
                if current_difficulty == "EASY":
                    move_pool = MOVES_EASY
                else:
                    move_pool = MOVES_ALL

                play_start = None
                play_move = pick_new_move(play_move, move_pool)
                move_start_enc_pos = encoder.position
                play_result = ""
                pixels[0] = (50, 50, 0)  # back to yellow

            continue

        # ── FAILURE HANDLING ────────────────────────────────
        if fail:
            play_result = "WRONG MOVE!"
            pending_score = score
            game_state = STATE_RESULT
            pixels[0] = (120, 0, 0)  # red — game over
            snd.play_fail()

        elif elapsed > time_limit:
            play_result = "TIME UP!"
            pending_score = score
            game_state = STATE_RESULT
            pixels[0] = (120, 0, 0)
            snd.play_fail()

    # ── RESULT STATE ────────────────────────────────────────
    # Shows final score and reason for game end. Encoder
    # button advances to high score entry (if qualified)
    # or directly to the high score table.
    elif game_state == STATE_RESULT:
        show_text([
            f"Rounds: {round_num}/{MAX_ROUNDS}",
            f"{play_result}",
            "",
            f"Score: {pending_score}",
            "Enc btn: continue"
        ])

        if enc_button_pressed:
            if hs.qualifies_for_highscore(highscores, pending_score):
                hs_initials = ["A", "A", "A"]
                hs_pos = 0
                hs_last_enc_pos = encoder.position
                game_state = STATE_HS_ENTRY
            else:
                game_state = STATE_HS_SHOW

    # ── HIGH SCORE ENTRY STATE ──────────────────────────────
    # Three-character initial entry using the rotary encoder.
    # Rotate to cycle A-Z, press to advance to next character.
    # This mirrors classic arcade high score entry — a
    # deliberate nostalgia choice matching the Bop It theme.
    elif game_state == STATE_HS_ENTRY:
        current_pos = encoder.position

        if current_pos > hs_last_enc_pos:
            idx = ord(hs_initials[hs_pos]) - ord('A')
            idx = (idx + 1) % 26
            hs_initials[hs_pos] = chr(ord('A') + idx)
        elif current_pos < hs_last_enc_pos:
            idx = ord(hs_initials[hs_pos]) - ord('A')
            idx = (idx - 1) % 26
            hs_initials[hs_pos] = chr(ord('A') + idx)

        hs_last_enc_pos = current_pos

        # Visual bracket indicator for active character
        c0, c1, c2 = hs_initials
        if hs_pos == 0:
            line = f"[{c0}] {c1} {c2}"
        elif hs_pos == 1:
            line = f"{c0} [{c1}] {c2}"
        else:
            line = f"{c0} {c1} [{c2}]"

        show_text([
            "NEW HIGH SCORE!",
            f"Score: {pending_score}",
            "",
            "Enter Initials:",
            line,
            "Enc: next letter"
        ])

        if enc_button_pressed:
            if hs_pos < 2:
                hs_pos += 1
            else:
                # Save completed initials to persistent storage
                initials = "".join(hs_initials)
                highscores = hs.insert_highscore(highscores, initials, pending_score)
                hs.save_highscores(highscores)
                game_state = STATE_HS_SHOW

    # ── HIGH SCORE DISPLAY STATE ────────────────────────────
    # Shows top 3 scores stored in on-device flash. Encoder
    # button returns to menu.
    elif game_state == STATE_HS_SHOW:
        lines = ["HIGH SCORES"]
        for idx, entry in enumerate(highscores[:3], start=1):
            lines.append(f"{idx}. {entry['initials']} {entry['score']}")
        lines.append("")
        lines.append("Enc btn: menu")

        show_text(lines)

        if enc_button_pressed:
            game_state = STATE_MENU
            menu_index = 0
            last_enc_pos = enc_pos
            pixels[0] = (0, 0, 50)  # dim blue — menu idle

    # ── FAILSAFE ────────────────────────────────────────────
    # If the state somehow becomes invalid, reset to menu.
    # This should never trigger in normal operation but
    # prevents a hard lock on the device.
    else:
        game_state = STATE_MENU
        menu_index = 0
        last_enc_pos = enc_pos
        show_text(["Motion Maven", "Resetting..."])
        pixels[0] = (50, 0, 0)

    # ── Loop Timing ─────────────────────────────────────────
    # 10 ms sleep (~100 Hz) keeps encoder and accelerometer
    # responsive. Faster polling showed no perceptible
    # improvement; slower polling (50+ ms) caused missed
    # encoder detents during fast spins.
    time.sleep(0.01)
